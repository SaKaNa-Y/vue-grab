{
  "name": "vue-grab-monorepo",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.24.0",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10.0.0"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "dev:playground": "pnpm --filter playground dev",
    "docs:dev": "pnpm --filter docs dev",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "lint": "oxlint --vue-plugin --vitest-plugin packages/ playground/ docs/",
    "lint:fix": "oxlint --fix --vue-plugin --vitest-plugin packages/ playground/ docs/",
    "format": "oxfmt --write packages/ playground/ docs/",
    "format:check": "oxfmt --check packages/ playground/ docs/",
    "release": "changeset publish",
    "version-packages": "dotenv -e .env -- changeset version",
    "version-packages:ci": "changeset version && pnpm format"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.5.1",
    "@changesets/cli": "^2.27.12",
    "dotenv-cli": "^11.0.0",
    "oxfmt": "^0.43.0",
    "oxlint": "^1.58.0",
    "turbo": "^2.8.0",
    "typescript": "~5.9.3"
  }
}
