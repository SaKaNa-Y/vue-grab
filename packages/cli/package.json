{
  "name": "@sakana-y/vue-grab-cli",
  "version": "0.1.1",
  "private": false,
  "description": "CLI setup tool for adding Vue Grab to Vite and Vue projects.",
  "keywords": [
    "ai",
    "cli",
    "debugging",
    "devtools",
    "scaffold",
    "vite",
    "vue"
  ],
  "bugs": {
    "url": "https://github.com/SaKaNa-Y/vue-grab/issues"
  },
  "license": "MIT",
  "author": "SaKaNa-Y",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SaKaNa-Y/vue-grab.git",
    "directory": "packages/cli"
  },
  "bin": {
    "vue-grab": "./dist/bin.mjs"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "vite build",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "cac": "^6.7.14",
    "picocolors": "^1.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "~5.9.3",
    "vite": "^8.0.0",
    "vite-plugin-dts": "^4.5.0",
    "vitest": "^4.1.0"
  }
}
