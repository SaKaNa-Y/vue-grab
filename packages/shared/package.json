{
  "name": "@sakana-y/vue-grab-shared",
  "version": "0.1.2",
  "private": false,
  "description": "Shared types, defaults, config merging, and protocol constants for Vue Grab integrations.",
  "keywords": [
    "ai",
    "configuration",
    "devtools",
    "protocol",
    "types",
    "vite",
    "vue"
  ],
  "bugs": {
    "url": "https://github.com/SaKaNa-Y/vue-grab/issues"
  },
  "license": "MIT",
  "author": "SaKaNa-Y",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SaKaNa-Y/vue-grab.git",
    "directory": "packages/shared"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "vite build",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "typescript": "~5.9.3",
    "vite": "^8.0.0",
    "vite-plugin-dts": "^4.5.0",
    "vitest": "^4.1.0"
  }
}
